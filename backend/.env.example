# ── Database (MySQL เดิม febcthcom_dev24) ──
# ใน Docker ต่อ host ผ่าน host.docker.internal; รันบน host ตรงๆ ใช้ 127.0.0.1
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=febcthcom_dev24
DB_USERNAME=febc_api
DB_PASSWORD=FebcApi#2026

# ── Auth ──
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
COOKIE_NAME=febc_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── App ──
CORS_ORIGINS=http://localhost:3000
MEDIA_DIR=/app/media

# ── Login throttle ──
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=10
